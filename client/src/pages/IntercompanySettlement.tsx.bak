/**
 * Intercompany Settlement — Command Center
 * Cross-Entity Settlement Module — Bitstamp × Ripple Treasury
 *
 * Design system: nav_v2 light tokens · purple (#9c47ff) Netting accent
 * Layout: TreasuryShell → three-panel (Net Positions | FBO Balances | In-Flight)
 * Features: batch configurator drawer, pre-go summary overlay, provenance modal
 */

import { useState, useEffect, useRef, Fragment } from "react";
import { motion, AnimatePresence } from "framer-motion";
import TreasuryShell from "@/components/TreasuryShell";
import {
  Zap, ChevronRight, ChevronDown, X, AlertTriangle,
  CheckCircle, Clock, Building2, ArrowRight, RefreshCcw,
  BarChart3, FileText, LayoutList, Table2, Download,
} from "lucide-react";

// ─── Types ────────────────────────────────────────────────────────────────────

type Currency = "USD" | "EUR" | "GBP";
type Entity   = "SA" | "LTD" | "INC" | "BVI" | "BFS" | "MTF";
type TxType   = "Trade" | "Deposit" | "Ripple IOU" | "OTC" | "Derivatives";
type Urgency  = "critical" | "watch" | "clear";
type InstructionStatus =
  | "submitted" | "in_payments" | "first_signed" | "second_signed"
  | "sent_to_bank" | "confirmed" | "failed";
type RoutingKind = "instant" | "banking_window" | "manual";
type SettlementType =
  | "Trade settlement"
  | "Creditcard settlement"
  | "Ripple settlement"
  | "Deposit settlement"
  | "OTC trade settlement"
  | "Derivatives settlement"
  | "Derivatives IF claim"
  | "Derivatives IF premium"
  | "Derivatives FEE sweep"
  | "Derivatives liquidation"
  | "Derivatives"
  | "Account transfers"
  | "Withdrawals";

const SETTLEMENT_TYPES: SettlementType[] = [
  "Trade settlement",
  "Creditcard settlement",
  "Ripple settlement",
  "Deposit settlement",
  "OTC trade settlement",
  "Derivatives settlement",
  "Derivatives IF claim",
  "Derivatives IF premium",
  "Derivatives FEE sweep",
  "Derivatives liquidation",
  "Derivatives",
  "Account transfers",
  "Withdrawals",
];

interface ReportRow {
  id: string;
  from: Entity;
  to: Entity;
  currency: Currency;
  toSettle: number;
  totalBalance: number;
  previouslySettled: number;
  settlementTx: string | null;
  ref: string | null;
  rowStatus: "Unsettled" | "Settled" | "Processing";
  isInverse?: boolean; // red row — payment goes To → From
}

interface TxBreakdown {
  type: TxType;
  amount: number;
  count: number;
}

interface NetPosition {
  id: string;
  from: Entity;
  to: Entity;
  currency: Currency;
  amount: number;
  threshold: number;
  urgency: Urgency;
  lastSettledDaysAgo: number;
  breakdown: TxBreakdown[];
  isSkipNode?: boolean;
  skipVia?: Entity;
}

interface FBOAccount {
  id: string;
  entity: Entity;
  bank: string;
  currency: Currency;
  balance: number;
  batchApplied: number;
  isFBO: boolean;
  routing: RoutingKind;
  windowCountdown?: string;
  windowUrgent?: boolean;
  exposureUsed?: number;
  exposureLimit?: number;
  lastUpdatedMins: number;
}

interface InFlight {
  id: string;
  traceId: string;
  from: Entity;
  to: Entity;
  currency: Currency;
  amount: number;
  status: InstructionStatus;
  routing: RoutingKind;
  bank: string;
  isSkipNode?: boolean;
  failureReason?: string;
  icsWriteback?: "confirmed" | "pending" | "failed";
  timestamp: string;
  bankRef?: string;
}

interface ConfigPosition {
  positionId: string;
  action: "full" | "partial" | "defer" | null;
  partialAmount: number;
}

