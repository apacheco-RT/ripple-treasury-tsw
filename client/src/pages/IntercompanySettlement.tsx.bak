// ─── Settlement Report Table ────────────────────────────────────────────────────

function SettlementReportTable({ settlementType }: { settlementType: SettlementType }) {
  const currentRows = REPORT_ROWS[settlementType] ?? [];
  const [rowStatuses, setRowStatuses] = useState<Record<string, ReportRow["rowStatus"]>>(
    Object.fromEntries(currentRows.map(r => [r.id, r.rowStatus]))
  );

  // Reset statuses when settlement type changes
  useEffect(() => {
    const newRows = REPORT_ROWS[settlementType] ?? [];
    setRowStatuses(Object.fromEntries(newRows.map(r => [r.id, r.rowStatus])));
  }, [settlementType]);

  const unsettledCount = currentRows.filter(r => (rowStatuses[r.id] ?? r.rowStatus) === "Unsettled").length;
  const settledCount   = currentRows.filter(r => (rowStatuses[r.id] ?? r.rowStatus) === "Settled").length;

  // Group by currency
  const currencies = Array.from(new Set(currentRows.map(r => r.currency)));

  return (
    <div className="flex flex-col h-full overflow-hidden">
      {/* Table toolbar */}
      <div className="flex items-center justify-between px-6 py-3 bg-white border-b border-[#e2e8f0]">
        <div className="flex items-center gap-4 text-xs text-[#64748b]">
          <span><span className="font-semibold text-[#0f172a]">{currentRows.length}</span> rows</span>
          <span className="text-[#e2e8f0]">·</span>
          <span><span className="font-semibold text-amber-600">{unsettledCount}</span> unsettled</span>
          <span className="text-[#e2e8f0]">·</span>
          <span><span className="font-semibold text-green-600">{settledCount}</span> settled</span>
          <span className="text-[#e2e8f0]">·</span>
          <span>Total: <span className="font-semibold text-[#0f172a]">{
            currencies.map(c => {
              const sum = currentRows.filter(r => r.currency === c).reduce((s, r) => s + r.toSettle, 0);
              const sym = c === "USD" ? "$" : c === "EUR" ? "€" : "£";
              return `${sym}${(sum / 1_000_000).toFixed(1)}M ${c}`;
            }).join(" + ")
          }</span></span>
        </div>
        <div className="flex items-center gap-2">
          <button className="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-[#e2e8f0] text-xs text-[#475569] hover:bg-[#f8fafc] transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#9c47ff]/50">
            <Download className="h-3 w-3" />
            Export Source Transactions
          </button>
          <button className="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-[#e2e8f0] text-xs text-[#475569] hover:bg-[#f8fafc] transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#9c47ff]/50">
            <FileText className="h-3 w-3" />
            Export Report
          </button>
        </div>
      </div>

      {/* Table */}
      <div className="flex-1 overflow-y-auto">
        <table className="w-full text-sm border-collapse">
          <thead className="sticky top-0 z-10">
            <tr className="bg-[#f8fafc] border-b border-[#e2e8f0]">
              <th className="text-left px-4 py-2.5 text-[11px] font-semibold uppercase tracking-wider text-[#64748b] whitespace-nowrap">From</th>
              <th className="text-center px-2 py-2.5 text-[11px] font-semibold uppercase tracking-wider text-[#64748b]"></th>
              <th className="text-left px-4 py-2.5 text-[11px] font-semibold uppercase tracking-wider text-[#64748b] whitespace-nowrap">To</th>
              <th className="text-right px-4 py-2.5 text-[11px] font-semibold uppercase tracking-wider text-[#64748b] whitespace-nowrap">To Settle</th>
              <th className="text-left px-4 py-2.5 text-[11px] font-semibold uppercase tracking-wider text-[#64748b]">Calculation</th>
              <th className="text-left px-4 py-2.5 text-[11px] font-semibold uppercase tracking-wider text-[#64748b] whitespace-nowrap">Settlement tx</th>
              <th className="text-left px-4 py-2.5 text-[11px] font-semibold uppercase tracking-wider text-[#64748b]">Ref</th>
              <th className="text-left px-4 py-2.5 text-[11px] font-semibold uppercase tracking-wider text-[#64748b]">Status</th>
            </tr>
          </thead>
          <tbody>
            {currencies.map(currency => {
              const currencyRows = currentRows.filter(r => r.currency === currency);
              const currencyTotal = currencyRows.reduce((s, r) => s + r.toSettle, 0);
              const sym = currency === "USD" ? "$" : currency === "EUR" ? "€" : "£";
              return (
                <Fragment key={currency}>
                  {/* Currency section header */}
                  <tr className="bg-[#f1f5f9] border-y border-[#e2e8f0]">
                    <td colSpan={7} className="px-4 py-1.5">
                      <span className="text-[11px] font-bold uppercase tracking-wider text-[#475569]">{currency}</span>
                    </td>
                    <td className="px-4 py-1.5 text-right">
                      <span className="text-[11px] font-bold text-[#0f172a]">
                        {sym}{(currencyTotal / 1_000_000).toFixed(2)}M
                      </span>
                    </td>
                  </tr>
                  {currencyRows.map((row, idx) => {
                    const status = rowStatuses[row.id] ?? row.rowStatus;
                    const isInverse = row.isInverse;
                    return (
                      <tr
                        key={row.id}
                        className={`border-b border-[#f1f5f9] transition-colors ${
                          isInverse
                            ? "bg-red-50 hover:bg-red-100/60"
                            : idx % 2 === 0
                              ? "bg-white hover:bg-[#fafbff]"
                              : "bg-[#fafcff] hover:bg-[#fafbff]"
                        }`}
                      >
                        {/* From */}
                        <td className="px-4 py-2.5">
                          <div className="flex items-center gap-2">
                            <div className="w-6 h-6 rounded-full bg-violet-100 flex items-center justify-center">
                              <span className="text-[9px] font-bold text-violet-700">{row.from}</span>
                            </div>
                            <span className="text-xs font-medium text-[#0f172a]">{row.from}</span>
                          </div>
                        </td>
                        {/* Direction arrow */}
                        <td className="px-2 py-2.5 text-center">
                          {isInverse ? (
                            <span className="text-red-500 font-bold text-sm">←</span>
                          ) : (
                            <span className="text-[#94a3b8]">→</span>
                          )}
                        </td>
                        {/* To */}
                        <td className="px-4 py-2.5">
                          <div className="flex items-center gap-2">
                            <div className="w-6 h-6 rounded-full bg-slate-100 flex items-center justify-center">
                              <span className="text-[9px] font-bold text-slate-600">{row.to}</span>
                            </div>
                            <span className="text-xs font-medium text-[#0f172a]">{row.to}</span>
                          </div>
                        </td>
                        {/* To Settle */}
                        <td className="px-4 py-2.5 text-right">
                          <span className={`text-sm font-semibold ${isInverse ? "text-red-700" : "text-[#0f172a]"}`}>
                            {sym}{(row.toSettle / 1_000_000).toFixed(2)}M
                          </span>
                        </td>
                        {/* Calculation */}
                        <td className="px-4 py-2.5">
                          <div className="text-[11px] text-[#64748b] font-mono whitespace-nowrap">
                            {sym}{(row.totalBalance / 1_000_000).toFixed(2)}M
                            {row.previouslySettled > 0 && (
                              <> <span className="text-red-500">− {sym}{(row.previouslySettled / 1_000_000).toFixed(2)}M</span></>
                            )}
                            <span className="text-[#94a3b8]"> = </span>
                            <span className="text-[#0f172a] font-semibold">{sym}{(row.toSettle / 1_000_000).toFixed(2)}M</span>
                          </div>
                        </td>
                        {/* Settlement tx */}
                        <td className="px-4 py-2.5">
                          {row.settlementTx ? (
                            <span className="text-[11px] font-mono text-[#006aff] truncate max-w-[140px] block">{row.settlementTx}</span>
                          ) : (
                            <span className="text-[11px] text-[#94a3b8]">—</span>
                          )}
                        </td>
                        {/* Ref */}
                        <td className="px-4 py-2.5">
                          <span className="text-[11px] font-mono text-[#475569]">{row.ref}</span>
                        </td>
                        {/* Status dropdown */}
                        <td className="px-4 py-2.5">
                          <div className="relative inline-block">
                            <select
                              value={status}
                              onChange={e => setRowStatuses(prev => ({ ...prev, [row.id]: e.target.value as ReportRow["rowStatus"] }))}
                              className={`text-[11px] font-medium pl-2 pr-6 py-1 rounded-lg border cursor-pointer transition-colors appearance-none ${
                                status === "Settled"    ? "bg-green-50 border-green-200 text-green-700" :
                                status === "Processing" ? "bg-blue-50 border-blue-200 text-blue-700" :
                                                          "bg-amber-50 border-amber-200 text-amber-700"
                              }`}
                            >
                              <option value="Unsettled">Unsettled</option>
                              <option value="Processing">Processing</option>
                              <option value="Settled">Settled</option>
                            </select>
                            <ChevronDown className="pointer-events-none absolute right-1.5 top-1/2 -translate-y-1/2 h-3 w-3 opacity-50" />
                          </div>
                        </td>
                      </tr>
                    );
                  })}
                </Fragment>
              );
            })}
          </tbody>
        </table>

        {currentRows.length === 0 && (
          <div className="flex flex-col items-center justify-center py-16 text-[#94a3b8]">
            <Table2 className="h-8 w-8 mb-3 opacity-40" />
            <p className="text-sm">No rows for this settlement type</p>
          </div>
        )}
      </div>

      {/* Table action bar */}
      <div className="shrink-0 px-6 py-3 bg-white border-t border-[#e2e8f0] flex items-center justify-between">
        <div className="flex items-center gap-2">
          <button className="px-3 py-2 rounded-lg border border-[#e2e8f0] text-xs text-[#475569] hover:bg-[#f8fafc] transition-all">
            Manual settlement
          </button>
          <button className="px-3 py-2 rounded-lg border border-[#e2e8f0] text-xs text-[#475569] hover:bg-[#f8fafc] transition-all">
            Consolidate transactions
          </button>
          <button className="px-3 py-2 rounded-lg border border-[#e2e8f0] text-xs text-[#475569] hover:bg-[#f8fafc] transition-all">
            <RefreshCcw className="h-3 w-3 inline mr-1" />
            Calculate new report
          </button>
        </div>
        <div className="flex items-center gap-2">
          <button className="px-3 py-2 rounded-lg border border-[#e2e8f0] text-xs text-[#475569] hover:bg-[#f8fafc] transition-all">
            Update Statuses
          </button>
          <button className="px-3 py-2 rounded-lg border border-[#e2e8f0] text-xs text-[#475569] hover:bg-[#f8fafc] transition-all">
            ← Previous
          </button>
          <button className="px-3 py-2 rounded-lg border border-[#e2e8f0] text-xs text-[#475569] hover:bg-[#f8fafc] transition-all">
            Next →
          </button>
          <button className="px-3 py-2 rounded-lg border border-[#e2e8f0] text-xs text-[#475569] hover:bg-[#f8fafc] transition-all">
            Last Report
          </button>
          <button className="flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold bg-[#9c47ff] text-white hover:bg-[#6417bf] shadow-sm shadow-[#9c47ff]/20 transition-all">
            Process
          </button>
        </div>
      </div>
    </div>
  );
}

// ─── Main Page ─────────────────────────────────────────────────────────────────

export default function IntercompanySettlement() {
  const [showConfigurator, setShowConfigurator] = useState(false);
  const [showPreGo, setShowPreGo] = useState(false);
  const [showToast, setShowToast] = useState(false);
  const [provenancePosition, setProvenancePosition] = useState<NetPosition | null>(null);
  const [activeView, setActiveView] = useState<"command" | "report">("command");
  const [settlementType, setSettlementType] = useState<SettlementType>("Trade settlement");
  const toastTimerRef = useRef<ReturnType<typeof setTimeout> | null>(null);
  const batchInFlight = IN_FLIGHT.some(i => ["submitted", "in_payments", "first_signed", "second_signed", "sent_to_bank"].includes(i.status));

  // Clean up toast timer on unmount
  useEffect(() => () => { if (toastTimerRef.current) clearTimeout(toastTimerRef.current); }, []);

  function handleConfiguratorSubmit() {
    setShowConfigurator(false);
    setShowPreGo(true);
  }

  function handleConfirm() {
    setShowPreGo(false);
    setShowToast(true);
    if (toastTimerRef.current) clearTimeout(toastTimerRef.current);
    toastTimerRef.current = setTimeout(() => setShowToast(false), 10000);
  }

  // Close provenance on Escape
  useEffect(() => {
    function handler(e: KeyboardEvent) {
      if (e.key === "Escape") {
        setProvenancePosition(null);
        setShowPreGo(false);
        setShowConfigurator(false);
      }
    }
    window.addEventListener("keydown", handler);
    return () => window.removeEventListener("keydown", handler);
  }, []);

  return (
    <TreasuryShell solution="Netting" activeFeature="Intercompany Settlement">
      <div className="flex flex-col h-full bg-[#f8fafc]">

        {/* Breadcrumb */}
        <nav className="flex items-center gap-1.5 text-sm px-6 pt-4 pb-2">
          <span className="text-[#64748b]">Netting</span>
          <ChevronRight className="h-3.5 w-3.5 text-[#94a3b8]" />
          <span className="font-medium text-[#0f172a]">Intercompany Settlement</span>
        </nav>

        {/* Page header */}
        <div className="px-6 pb-4">
          <div className="flex items-start gap-3">
            <div className="p-2 rounded-xl border shadow-sm bg-gradient-to-br from-violet-50 to-purple-100 border-violet-200 shrink-0">
              <Zap className="h-5 w-5 text-[#9c47ff]" />
            </div>
            <div className="pt-0.5 min-w-0">
              <h1 className="text-xl font-semibold tracking-tight text-[#0f172a]">Intercompany Settlement</h1>
              <p className="text-sm mt-0.5 text-[#64748b]">Command center — Batch #047 in flight</p>
            </div>
            <div className="ml-auto flex items-center gap-3 shrink-0">
              {/* Settlement type dropdown — only relevant in Report view */}
              <div className={`flex items-center gap-2 transition-opacity ${activeView === "command" ? "opacity-40 pointer-events-none" : ""}`}>
                <label htmlFor="settlement-type-select" className="text-xs text-[#64748b] whitespace-nowrap">Settlement type</label>
                <div className="relative">
                  <select
                    id="settlement-type-select"
                    tabIndex={activeView === "command" ? -1 : 0}
                    value={settlementType}
                    onChange={e => setSettlementType(e.target.value as SettlementType)}
                    className="appearance-none text-sm font-medium text-[#0f172a] bg-white border border-[#e2e8f0] rounded-lg pl-3 pr-8 py-2 cursor-pointer hover:border-[#9c47ff]/50 focus:outline-none focus:border-[#9c47ff] focus:ring-2 focus:ring-[#9c47ff]/10 transition-all min-w-[200px]"
                  >
                    {SETTLEMENT_TYPES.map(t => (
                      <option key={t} value={t}>{t}</option>
                    ))}
                  </select>
                  <ChevronDown className="pointer-events-none absolute right-2.5 top-1/2 -translate-y-1/2 h-3.5 w-3.5 text-[#94a3b8]" />
                </div>
              </div>

              {/* View toggle */}
              <div className="flex items-center rounded-lg border border-[#e2e8f0] p-0.5 bg-[#f8fafc]">
                <button
                  onClick={() => setActiveView("command")}
                  className={`flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-medium transition-all ${
                    activeView === "command"
                      ? "bg-white text-[#0f172a] shadow-sm border border-[#e2e8f0]"
                      : "text-[#64748b] hover:text-[#475569]"
                  }`}
                >
                  <LayoutList className="h-3.5 w-3.5" />
                  Command Center
                </button>
                <button
                  onClick={() => setActiveView("report")}
                  className={`flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-medium transition-all ${
                    activeView === "report"
                      ? "bg-white text-[#0f172a] shadow-sm border border-[#e2e8f0]"
                      : "text-[#64748b] hover:text-[#475569]"
                  }`}
                >
                  <Table2 className="h-3.5 w-3.5" />
                  Settlement Report
                </button>
              </div>

              <span className="text-xs text-[#94a3b8]">Calculated 08:42 UTC</span>
              <button className="text-xs px-3 py-1.5 rounded-lg border border-[#e2e8f0] text-[#475569] hover:bg-white hover:border-[#9c47ff]/40 hover:text-[#9c47ff] transition-all flex items-center gap-1.5">
                <RefreshCcw className="h-3 w-3" />
                Recalculate
              </button>
            </div>
          </div>
        </div>

        {/* Main content — conditionally render view */}
        {activeView === "command" ? (
          <>
            {/* Three-panel layout */}
            <div className="flex gap-4 flex-1 overflow-hidden px-6 pb-2 min-h-0">
              {/* Left: Net Positions */}
              <div className="w-[300px] shrink-0 flex flex-col gap-3 overflow-y-auto min-h-0">
                <NetPositionsPanel onProvenanceClick={setProvenancePosition} />
              </div>
              {/* Center: FBO Balances */}
              <div className="flex-1 flex flex-col gap-3 overflow-y-auto min-h-0">
                <FBOBalancesPanel />
              </div>
              {/* Right: In-Flight */}
              <div className="w-[280px] shrink-0 flex flex-col gap-3 overflow-y-auto min-h-0">
                <InFlightPanel />
              </div>
            </div>
            {/* Command center sticky bottom bar */}
            <div className="shrink-0 px-6 py-3 bg-white border-t border-[#e2e8f0] flex items-center justify-between">
              <div className="flex items-center gap-3 text-xs text-[#64748b] flex-wrap">
                <span>Batch #047 in flight</span>
                <span className="text-[#e2e8f0]">·</span>
                <span>7 instructions</span>
                <span className="text-[#e2e8f0]">·</span>
                <span>{IN_FLIGHT.filter(i => i.status === "confirmed").length} of {IN_FLIGHT.length} confirmed</span>
                <span className="text-[#e2e8f0]">·</span>
                <span className="text-red-600 font-medium">1 failed</span>
              </div>
              <div className="flex items-center gap-2">
                <button className="flex items-center gap-1.5 px-3 py-2 rounded-lg border border-[#e2e8f0] text-xs text-[#475569] hover:bg-[#f8fafc] transition-all">
                  <BarChart3 className="h-3.5 w-3.5" />
                  Analytics
                </button>
                <button className="flex items-center gap-1.5 px-3 py-2 rounded-lg border border-[#e2e8f0] text-xs text-[#475569] hover:bg-[#f8fafc] transition-all">
                  <FileText className="h-3.5 w-3.5" />
                  Export
                </button>
                <button
                  disabled={batchInFlight}
                  onClick={() => setShowConfigurator(true)}
                  className={`flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#9c47ff]/50 focus-visible:ring-offset-2 ${
                    batchInFlight
                      ? "bg-[#9c47ff]/20 text-[#9c47ff]/50 cursor-not-allowed"
                      : "bg-[#9c47ff] text-white hover:bg-[#6417bf] shadow-sm shadow-[#9c47ff]/20"
                  }`}
                >
                  <Zap className="h-4 w-4" />
                  {batchInFlight ? "Batch in flight — awaiting Payments" : "Configure New Batch"}
                </button>
              </div>
            </div>
          </>
        ) : (
          /* Settlement Report table view */
          <div className="flex-1 overflow-hidden flex flex-col">
            <SettlementReportTable settlementType={settlementType} />
          </div>
        )}
      </div>

      {/* Overlays */}
      <AnimatePresence>
        {showConfigurator && (
          <ConfiguratorDrawer
            onClose={() => setShowConfigurator(false)}
            onSubmit={handleConfiguratorSubmit}
          />
        )}
      </AnimatePresence>

      <AnimatePresence>
        {showPreGo && (
          <PreGoSummary
            onClose={() => setShowPreGo(false)}
            onConfirm={handleConfirm}
          />
        )}
      </AnimatePresence>

      {/* Provenance modal */}
      <AnimatePresence>
        {provenancePosition && (
          <ProvenanceModal
            position={provenancePosition}
            onClose={() => setProvenancePosition(null)}
          />
        )}
      </AnimatePresence>

      {/* Post-submit toast */}
      <AnimatePresence>
        {showToast && (
          <motion.div
            className="fixed bottom-6 right-6 z-50 bg-[#0f172a] text-white rounded-xl px-5 py-3 shadow-xl flex items-center gap-3 text-sm"
            initial={{ opacity: 0, y: 16 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: 16 }}
            transition={{ type: "spring", stiffness: 300, damping: 25 }}
          >
            <CheckCircle className="h-4 w-4 text-green-400 shrink-0" />
            <span>Batch #048 submitted — 4 instructions sent to Payments</span>
            <button onClick={() => setShowToast(false)} className="text-white/50 hover:text-white ml-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/70 rounded">
              <X className="h-3.5 w-3.5" />
            </button>
          </motion.div>
        )}
      </AnimatePresence>
    </TreasuryShell>
  );
}
